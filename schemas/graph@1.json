{
  "$defs": {
    "GraphEdge": {
      "additionalProperties": false,
      "properties": {
        "dst": {
          "title": "Dst",
          "type": "string"
        },
        "end": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End"
        },
        "kind": {
          "enum": [
            "reports_to",
            "works_at",
            "client_of",
            "participant"
          ],
          "title": "Kind",
          "type": "string"
        },
        "src": {
          "title": "Src",
          "type": "string"
        },
        "start": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start"
        }
      },
      "required": [
        "src",
        "dst",
        "kind"
      ],
      "title": "GraphEdge",
      "type": "object"
    }
  },
  "$id": "orgsmith/graph@1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "edges": {
      "items": {
        "$ref": "#/$defs/GraphEdge"
      },
      "title": "Edges",
      "type": "array"
    },
    "entities": {
      "items": {
        "type": "string"
      },
      "title": "Entities",
      "type": "array"
    },
    "schema_id": {
      "const": "orgsmith/graph@1",
      "default": "orgsmith/graph@1",
      "title": "Schema Id",
      "type": "string"
    },
    "slug": {
      "title": "Slug",
      "type": "string"
    }
  },
  "required": [
    "slug",
    "entities",
    "edges"
  ],
  "title": "GraphLedger",
  "type": "object"
}
