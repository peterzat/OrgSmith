{
  "$defs": {
    "Generator": {
      "additionalProperties": false,
      "description": "Which model, at which effort, authored one batch.\n\nA RECORD, not an oracle. Self-reported by the skill that dispatched the\npass and not recomputable from artifacts, so no validator rule may ever\nreference it: a rule would fake a guarantee the system cannot make.\nOptional and inert by default, which is what keeps deliverables written\nbefore it existed loading unchanged against the same schema ids.",
      "properties": {
        "effort": {
          "minLength": 1,
          "title": "Effort",
          "type": "string"
        },
        "model": {
          "minLength": 1,
          "title": "Model",
          "type": "string"
        }
      },
      "required": [
        "model",
        "effort"
      ],
      "title": "Generator",
      "type": "object"
    },
    "ReviewFinding": {
      "additionalProperties": false,
      "properties": {
        "dimension": {
          "enum": [
            "org_realism",
            "finance_realism",
            "narrative_consistency",
            "document_plausibility",
            "graph_acl_naturalness",
            "cross_document_voice"
          ],
          "title": "Dimension",
          "type": "string"
        },
        "docs": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Docs",
          "type": "array"
        },
        "evidence": {
          "default": "",
          "title": "Evidence",
          "type": "string"
        },
        "id": {
          "pattern": "^rf:[a-z0-9][a-z0-9._-]*$",
          "title": "Id",
          "type": "string"
        },
        "schema_id": {
          "const": "orgsmith/review-finding@1",
          "default": "orgsmith/review-finding@1",
          "title": "Schema Id",
          "type": "string"
        },
        "severity": {
          "enum": [
            "blocker",
            "major",
            "minor",
            "note"
          ],
          "title": "Severity",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "id",
        "dimension",
        "severity",
        "summary"
      ],
      "title": "ReviewFinding",
      "type": "object"
    }
  },
  "$id": "orgsmith/review-findings@1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "The board's deliverable: one reviewer's findings for one org.\n\nSame shape of contract as an authoring deliverable -- validated and\nmerged all-or-nothing by `review --ingest`, never trusted as written.",
  "properties": {
    "dimension": {
      "enum": [
        "org_realism",
        "finance_realism",
        "narrative_consistency",
        "document_plausibility",
        "graph_acl_naturalness",
        "cross_document_voice"
      ],
      "title": "Dimension",
      "type": "string"
    },
    "findings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ReviewFinding"
      },
      "title": "Findings",
      "type": "array"
    },
    "generator": {
      "anyOf": [
        {
          "$ref": "#/$defs/Generator"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "schema_id": {
      "const": "orgsmith/review-findings@1",
      "default": "orgsmith/review-findings@1",
      "title": "Schema Id",
      "type": "string"
    },
    "slug": {
      "title": "Slug",
      "type": "string"
    }
  },
  "required": [
    "slug",
    "dimension"
  ],
  "title": "ReviewFindings",
  "type": "object"
}
